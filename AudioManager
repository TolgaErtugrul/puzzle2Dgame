using UnityEngine;
using UnityEngine.UI;

public class AudioManager : MonoBehaviour
{
    public static AudioManager Instance;
    public AudioSource musicSource;
    public AudioSource sfxSource;

    void Awake()
    {
        Instance = this;
        // Kayıtlı ses ayarını yükle (Varsayılan: 1 yani Açık)
        float savedVolume = PlayerPrefs.GetFloat("MusicVolume", 1f);
        musicSource.volume = savedVolume;
    }

    public void ToggleMusic(bool isOn)
    {
        float volume = isOn ? 1f : 0f;
        musicSource.volume = volume;
        PlayerPrefs.SetFloat("MusicVolume", volume);
        PlayerPrefs.Save();
    }

    public void PlayTokSFX(AudioClip clip, float pitch = 1.0f)
    {
        if (clip == null) return;
        
        // Geçici bir AudioSource oluşturup sesi çalmak için (üst üste binmeler için)
        audioSource.pitch = pitch; // Sesi pesleştirmek için 1.0'dan küçük değerler (0.8 gibi)
        audioSource.PlayOneShot(clip);
    }

    public void TriggerVibration(bool isStrong)
    {
        #if UNITY_ANDROID || UNITY_IOS
        if (isStrong) {
            // Bomba için daha belirgin (bazı cihazlarda standart titreşim)
            Handheld.Vibrate(); 
        } else {
            // Hatalı seçim için kısa titreşim (Android için özel plugin yoksa 
            // standart titreşim kullanılır, gerçek cihazda test edilmeli)
            Handheld.Vibrate();
        }
        #endif
    }
}
