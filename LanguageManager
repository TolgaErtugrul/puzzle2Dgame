public enum Language { TR, EN }

public static class LanguageManager
{
    public static Language currentLanguage = Language.TR;

    public static string GetText(string key)
    {
        bool isTR = currentLanguage == Language.TR;

        switch (key)
        {
            case "time": return isTR ? "Süre: " : "Time: ";
            case "moves": return isTR ? "Hamle: " : "Moves: ";
            case "next": return isTR ? "Sonraki Bölüm" : "Next Level";
            case "tryAgain": return isTR ? "Tekrar Dene" : "Try Again";
            case "plus30": return isTR ? "+30 Saniye" : "+30 Seconds";
            case "settingsTitle": return isTR ? "AYARLAR" : "SETTINGS";
            case "langLabel": return isTR ? "DİL: " : "LANG: ";
            case "warning": return isTR ? "Hatalı seçim! -2s" : "Wrong move! -2s";
            case "theme_fruit": return isTR ? "YENİ TEMA: MEYVELER" : "NEW THEME: FRUITS";
            case "theme_animal": return isTR ? "YENİ TEMA: HAYVANLAR" : "NEW THEME: ANIMALS";
            case "theme_emoji": return isTR ? "YENİ TEMA: EMOJİLER" : "NEW THEME: EMOJIS";
            case "theme_letter": return isTR ? "YENİ TEMA: HARFLER" : "NEW THEME: LETTERS";
            case "theme_food": return isTR ? "YENİ TEMA: YEMEKLER" : "NEW THEME: FOODS";
            case "bonus_match": return isTR ? "ÖDÜLLÜ EŞLEŞME! +5sn" : "BONUS MATCH! +5s";
            case "bomb_hit": return isTR ? "BOMBA! KARTLAR KAPANIYOR!" : "BOMB! CLOSING CARDS!";
            case "shuffling": return isTR ? "KARTLAR KARIŞIYOR!" : "SHUFFLING CARDS!";
            default: return "";
        }
    }
}
