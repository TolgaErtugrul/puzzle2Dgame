public enum Language { TR, EN }

public static class LanguageManager
{
    public static Language currentLanguage = Language.TR; // Varsayılan

    public static string GetText(string key)
    {
        if (currentLanguage == Language.TR)
        {
            switch (key)
            {
                case "time": return "Süre: ";
                case "moves": return "Hamle: ";
                case "next": return "Sonraki Bölüm";
                case "tryAgain": return "Tekrar Dene";
                case "plus30": return "+30 Saniye";
                case "settingsTitle": return "AYARLAR";
                case "langLabel": return "DİL: ";
                case "warning": return "Hatalı seçim! -3s";
                default: return "";
            }
        }
        else // EN
        {
            switch (key)
            {
                case "time": return "Time: ";
                case "moves": return "Moves: ";
                case "next": return "Next Level";
                case "tryAgain": return "Try Again";
                case "plus30": return "+30 Seconds";
                case "settingsTitle": return "SETTINGS";
                case "langLabel": return "LANG: ";
                case "warning": return "Wrong move! -3s";
                default: return "";
            }
        }
    }
}
