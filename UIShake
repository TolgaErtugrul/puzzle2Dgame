using UnityEngine;
using System.Collections;

public class UIShake : MonoBehaviour
{
    public static UIShake Instance;
    private Vector3 _originalPos;

    void Awake()
    {
        Instance = this;
        _originalPos = transform.localPosition;
    }

    public void Shake(float duration, float magnitude)
    {
        // Önceki sarsıntı bitmemişse pozisyonu sıfırla ki kayma yapmasın
        StopAllCoroutines();
        transform.localPosition = _originalPos;
        StartCoroutine(ShakeRoutine(duration, magnitude));
    }

    private IEnumerator ShakeRoutine(float duration, float magnitude)
    {
        float elapsed = 0.0f;

        while (elapsed < duration)
        {
            // Sarsıntı miktarını Pixel 5 gibi ekranlar için biraz artırdık
            float x = Random.Range(-1f, 1f) * magnitude * 20f; 
            float y = Random.Range(-1f, 1f) * magnitude * 20f;

            transform.localPosition = new Vector3(_originalPos.x + x, _originalPos.y + y, _originalPos.z);

            elapsed += Time.deltaTime;
            yield return null;
        }

        transform.localPosition = _originalPos;
    }
}
